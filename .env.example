# FastAPI Configuration
APP_NAME=INFERNO
APP_VERSION=0.1.0
DEBUG=False
HOST=0.0.0.0
PORT=8000

# LangChain Configuration
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_ENVIRONMENT=development
LANGCHAIN_TRACING_V2=true

# Base44 Integration
BASE44_API_KEY=your_base44_api_key_here
BASE44_API_URL=https://app.base44.com/api
BASE44_ENVIRONMENT=development

# OpenAI (for LangChain)
OPENAI_API_KEY=your_openai_api_key_here

# Database
DATABASE_URL=postgresql://user:password@localhost/inferno_db

# Security
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Replit Configuration (if running on Replit)
REPLIT_ENVIRONMENT=false

# Logging
LOG_LEVEL=INFO
